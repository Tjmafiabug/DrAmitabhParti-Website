---
import { site } from '../data/site';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');
---

<header class="sticky top-0 z-40 bg-[var(--color-surface)]/90 backdrop-blur-sm">
  <div class="container-wide px-6 py-5 flex items-center justify-between gap-6">
    <a href="/" class="group">
      <span class="font-[var(--font-headline)] text-[1.1rem] font-semibold uppercase tracking-tight text-[var(--color-on-surface)] transition-colors group-hover:text-[var(--color-primary)]">
        Dr. Amitabh Parti
      </span>
    </a>

    <nav aria-label="Primary" class="hidden md:block">
      <ul class="flex items-center gap-10">
        {site.nav.map((item) => {
          const active = isActive(item.href);
          return (
            <li>
              <a
                href={item.href}
                class={`font-[var(--font-label)] uppercase tracking-[0.2em] text-[0.72rem] pb-1 transition-colors ${active ? 'text-[var(--color-primary)] border-b border-[var(--color-primary)]' : 'text-[var(--color-secondary)] hover:text-[var(--color-primary)]'}`}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <!-- Mobile menu trigger -->
    <button
      id="mobile-nav-open"
      class="md:hidden font-[var(--font-label)] text-[0.72rem] uppercase tracking-[0.2em] text-[var(--color-on-surface)] flex items-center gap-2"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-nav"
      type="button"
    >
      <span>Menu</span>
      <span aria-hidden="true" class="text-[1.1rem] leading-none">≡</span>
    </button>
  </div>
</header>

<!-- Mobile nav drawer -->
<div id="mobile-nav" class="mobile-nav md:hidden" aria-hidden="true">
  <div class="h-full flex flex-col">
    <div class="flex items-center justify-between px-6 py-5">
      <span class="font-[var(--font-headline)] text-[1.1rem] font-semibold uppercase tracking-tight">Dr. Amitabh Parti</span>
      <button id="mobile-nav-close" aria-label="Close menu" class="font-[var(--font-label)] text-[0.72rem] uppercase tracking-[0.2em] flex items-center gap-2" type="button">
        <span>Close</span>
        <span aria-hidden="true" class="text-[1.1rem] leading-none">×</span>
      </button>
    </div>
    <nav aria-label="Primary mobile" class="flex-1 flex flex-col justify-center px-8">
      {site.nav.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
    </nav>
    <div class="px-8 pb-10">
      <p class="label text-[var(--color-secondary)]">{site.role} · {site.institutionShort}</p>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const openBtn = document.getElementById('mobile-nav-open');
    const closeBtn = document.getElementById('mobile-nav-close');
    const drawer = document.getElementById('mobile-nav');
    if (!openBtn || !closeBtn || !drawer) return;

    const open = () => {
      drawer.classList.add('open');
      drawer.setAttribute('aria-hidden', 'false');
      openBtn.setAttribute('aria-expanded', 'true');
      document.documentElement.style.overflow = 'hidden';
    };
    const close = () => {
      drawer.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
      openBtn.setAttribute('aria-expanded', 'false');
      document.documentElement.style.overflow = '';
    };

    openBtn.addEventListener('click', open);
    closeBtn.addEventListener('click', close);
    drawer.querySelectorAll('a').forEach((a) => a.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
    window.addEventListener('astro:before-swap', close);
  })();
</script>
