---
interface Props {
  eyebrow: string;
  title: string;
  titleItalic?: string;
  kicker?: string;
}
const { eyebrow, title, titleItalic, kicker } = Astro.props;
---

<section class="page-hero">
  <div class="container">
    <div class="page-hero__inner">
      <p class="page-hero__eyebrow">{eyebrow}</p>
      <h1 class="page-hero__title">
        {title}{titleItalic && <><br /><em>{titleItalic}</em></>}
      </h1>
      {kicker && <p class="page-hero__kicker">{kicker}</p>}
    </div>
  </div>
</section>
