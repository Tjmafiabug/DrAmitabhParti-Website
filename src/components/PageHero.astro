---
/*
  Compressed dark hero — house pattern for subsidiary pages.
  Matches Home's dark band tone but shorter height (no portrait, no quote).
*/
interface Props {
  eyebrow: string;
  title: string;
  titleItalic?: string;   // optional italic emphasis in title
  kicker?: string;         // optional small descriptive paragraph under title
}
const { eyebrow, title, titleItalic, kicker } = Astro.props;
---

<section class="section-dark-hero">
  <div class="container-wide mx-auto px-6 py-14 md:py-20">
    <p class="label mb-5" style="color: var(--color-gold-soft);">
      <span class="inline-block h-px w-8 align-middle mr-3" style="background: var(--color-gold-soft);"></span>
      {eyebrow}
    </p>
    <h1 class="text-balance" style="color: #f4efdf;">
      {title}{titleItalic && <><br /><span class="italic font-light" style="color: var(--color-gold-soft);">{titleItalic}</span></>}
    </h1>
    {kicker && (
      <p class="mt-6 max-w-2xl leading-relaxed text-[1.05rem] opacity-85 text-pretty">
        {kicker}
      </p>
    )}
  </div>
</section>
