---
import { getSettings } from '../lib/settings';

const settings = await getSettings();
const { identity, footer } = settings;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__top">
      <div class="footer__brand">
        <p class="footer__brand-name">{footer.brand_line || identity.name}</p>
        <p class="footer__tagline">{footer.tagline || 'Educational content only. Not a substitute for individual medical advice.'}</p>
      </div>

      <nav class="footer__nav" aria-label="Footer navigation">
        <div class="footer__col">
          <p class="footer__col-label">Read</p>
          {footer.read.map((l) => (
            <a href={l.href}>{l.label}</a>
          ))}
        </div>
        <div class="footer__col">
          <p class="footer__col-label">Correspond</p>
          {footer.correspond.map((l) => (
            <a href={l.href}>{l.label}</a>
          ))}
        </div>
        <div class="footer__col">
          <p class="footer__col-label">Legal</p>
          {footer.legal.map((l) => (
            <a href={l.href}>{l.label}</a>
          ))}
        </div>
      </nav>
    </div>

    <div class="footer__bottom">
      <p>&copy; {year} {identity.name}. All rights reserved.</p>
      <p>{identity.institution_short || identity.institution}, Gurgaon.</p>
    </div>
  </div>
</footer>
