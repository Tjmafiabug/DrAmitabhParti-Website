---
import { site } from '../data/site';
const year = new Date().getFullYear();
---

<footer class="section-dark-hero py-10 px-6">
  <div class="container-wide mx-auto">
    <!-- Top row: brand + 3 link columns inline -->
    <div class="grid gap-8 md:gap-12 md:grid-cols-[1.4fr_auto_auto_auto] items-start mb-8">
      <div>
        <p class="font-[var(--font-headline)] text-[1rem] font-semibold uppercase tracking-tight" style="color: #f4efdf;">Dr. Amitabh Parti</p>
      </div>

      <div>
        <p class="label mb-3 text-[0.65rem]" style="color: var(--color-gold-soft);">Read</p>
        <ul class="flex flex-col gap-1.5 text-[0.85rem]">
          {site.footer.read.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="label mb-3 text-[0.65rem]" style="color: var(--color-gold-soft);">Correspond</p>
        <ul class="flex flex-col gap-1.5 text-[0.85rem]">
          {site.footer.correspond.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="label mb-3 text-[0.65rem]" style="color: var(--color-gold-soft);">Fine Print</p>
        <ul class="flex flex-col gap-1.5 text-[0.85rem]">
          {site.footer.legal.map((l) => (
            <li><a href={l.href}>{l.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom strip: thin tonal divider + tight info row -->
    <div class="h-px w-full mb-5" style="background: rgba(221, 184, 128, 0.12);"></div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-[0.72rem]" style="color: var(--color-gold-soft); opacity: 0.7;">
      <p class="meta">© {year} Dr. Amitabh Parti</p>
      <p class="italic">Educational content only. Not a substitute for individual medical advice.</p>
      <p class="meta">amitabhparti.com</p>
    </div>
  </div>
</footer>
