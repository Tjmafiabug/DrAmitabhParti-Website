---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSettings } from '../lib/settings';
import { getPageBody } from '../lib/pages';

const settings = await getSettings();
const hero = settings.heroes.not_found;
const html = await getPageBody('not_found');
---

<BaseLayout pageKey="not_found">
  <section class="section-dark-hero">
    <div class="container-wide mx-auto px-6 py-24 md:py-32 text-center">
      <p class="label mb-6" style="color: var(--color-gold-soft);">
        <span class="inline-block h-px w-8 align-middle mr-3" style="background: var(--color-gold-soft);"></span>
        {hero.eyebrow}
      </p>
      <h1 class="mb-8 text-balance" style="color: #f4efdf;">
        {hero.title}{hero.title_italic && <><br/><span class="italic font-light" style="color: var(--color-gold-soft);">{hero.title_italic}</span></>}
      </h1>
      <div class="max-w-xl mx-auto leading-relaxed text-[1.05rem] opacity-85 mb-10" set:html={html} />
      <div class="flex flex-wrap items-center justify-center gap-8">
        <a href="/" class="font-[var(--font-label)] uppercase tracking-[0.2em] text-[0.7rem]" style="color: var(--color-gold-soft);">← Home</a>
        <a href="/writing" class="font-[var(--font-label)] uppercase tracking-[0.2em] text-[0.7rem]" style="color: var(--color-gold-soft);">Read the essays</a>
        <a href="/contact" class="font-[var(--font-label)] uppercase tracking-[0.2em] text-[0.7rem]" style="color: var(--color-gold-soft);">Contact</a>
      </div>
    </div>
  </section>
</BaseLayout>
