---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PageEditor from '../../../components/admin/PageEditor';
import { createSupabaseServerClient } from '../../../lib/supabase';

export const prerender = false;

const allowed = ['about', 'credentials'] as const;
const key = Astro.params.key as typeof allowed[number];
if (!allowed.includes(key)) return Astro.redirect('/admin/pages/about');

const titles: Record<string, string> = { about: 'About', credentials: 'Credentials' };

const supabase = createSupabaseServerClient(Astro);
const { data: page } = await supabase
  .from('pages')
  .select('body_json, body_html')
  .eq('key', key)
  .maybeSingle();
---

<AdminLayout title={`Edit — ${titles[key]}`}>
  <div class="admin-container">

    <div class="admin-tabs">
      <a href="/admin/pages/about" class={`admin-tab ${key === 'about' ? 'active' : ''}`}>About</a>
      <a href="/admin/pages/credentials" class={`admin-tab ${key === 'credentials' ? 'active' : ''}`}>Credentials</a>
    </div>

    <PageEditor
      client:only="react"
      pageKey={key}
      title={titles[key]}
      initialBodyJson={page?.body_json}
      initialBodyHtml={page?.body_html ?? ''}
    />
  </div>
</AdminLayout>
