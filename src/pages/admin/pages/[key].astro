---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PageEditor from '../../../components/admin/PageEditor';
import { createSupabaseServerClient } from '../../../lib/supabase';
import { PAGE_KEYS, PAGE_META, isPageKey } from '../../../lib/pages';

export const prerender = false;

const rawKey = Astro.params.key;
if (!isPageKey(rawKey)) return Astro.redirect('/admin/pages/about');
const key = rawKey;

const supabase = createSupabaseServerClient(Astro);
const { data: page } = await supabase
  .from('pages')
  .select('body_json, body_html')
  .eq('key', key)
  .maybeSingle();
---

<AdminLayout title={`Edit — ${PAGE_META[key].title}`}>
  <div class="admin-container">

    <div class="admin-tabs">
      {PAGE_KEYS.map((k) => (
        <a href={`/admin/pages/${k}`} class={`admin-tab ${key === k ? 'active' : ''}`}>
          {PAGE_META[k].title}
        </a>
      ))}
    </div>

    <PageEditor
      client:only="react"
      pageKey={key}
      title={PAGE_META[key].title}
      livePath={PAGE_META[key].livePath}
      initialBodyJson={page?.body_json}
      initialBodyHtml={page?.body_html ?? ''}
    />
  </div>
</AdminLayout>
