---
import AdminLayout from '../../layouts/AdminLayout.astro';
const error = Astro.url.searchParams.get('error');
const sent = Astro.url.searchParams.get('sent');
---

<AdminLayout title="Sign in">
  <div style="min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 2rem 1rem;">
    <div class="admin-card" style="width: 100%; max-width: 420px; padding: 2rem 2rem 1.75rem;">
      <div style="margin-bottom: 1.5rem;">
        <h1 style="font-size: 1.3rem; margin-bottom: 0.35rem;">Sign in</h1>
        <p class="admin-page-sub">amitabhparti.com administration</p>
      </div>

      {error === 'not_admin' && (
        <div class="admin-flash admin-flash-error">
          That email is not authorised for this administration. If you reached this page by mistake, please contact the site owner.
        </div>
      )}
      {error === 'exchange_failed' && (
        <div class="admin-flash admin-flash-error">
          That sign-in link has expired or was already used. Request a new one below.
        </div>
      )}
      {error === 'send_failed' && (
        <div class="admin-flash admin-flash-error">
          Couldn't send the sign-in email. Try again in a minute.
        </div>
      )}

      {sent ? (
        <div class="admin-flash admin-flash-info">
          <div>
            <p style="margin-bottom: 0.25rem; font-weight: 500;">Check your inbox</p>
            <p class="admin-meta">A sign-in link was sent to <strong>{sent}</strong>. The link expires in one hour.</p>
          </div>
        </div>
      ) : (
        <form method="post" action="/auth/signin">
          <div class="admin-field">
            <label for="email" class="admin-label">Email</label>
            <input type="email" id="email" name="email" required autocomplete="email" autofocus placeholder="you@example.com" class="admin-input" />
            <p class="admin-help">We'll email you a one-time sign-in link.</p>
          </div>
          <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%;">Send sign-in link</button>
        </form>
      )}

      <p class="admin-help" style="text-align: center; margin-top: 1.5rem;">
        Not expecting this? <a href="/" style="color: var(--a-primary); text-decoration: underline; text-underline-offset: 2px;">Return to the site</a>.
      </p>
    </div>
  </div>
</AdminLayout>
