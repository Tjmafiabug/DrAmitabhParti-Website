---
import AdminLayout from '../../layouts/AdminLayout.astro';
const error = Astro.url.searchParams.get('error');
const sent = Astro.url.searchParams.get('sent');
---

<AdminLayout title="Sign in">
  <section class="min-h-[100vh] flex items-center justify-center px-6 py-20">
    <div class="w-full max-w-md">
      <p class="label label-primary mb-4 text-center">Private Administration</p>
      <h1 class="text-center mb-3" style="font-size: clamp(1.8rem, 3vw + 0.5rem, 2.6rem); line-height: 1.1;">
        Sign in to <span class="italic">amitabhparti.com</span>
      </h1>
      <p class="text-center text-[var(--color-on-surface-variant)] mb-10 leading-relaxed">
        Enter your email. We'll send you a one-time sign-in link.
      </p>

      {error === 'not_admin' && (
        <div class="mb-6 p-4 border-l-2 text-[0.9rem] leading-relaxed" style="background: rgba(154, 74, 46, 0.06); border-color: var(--color-accent); color: var(--color-accent);">
          That email is not authorised for this administration. If you reached this message by mistake, please contact the site owner.
        </div>
      )}

      {sent && (
        <div class="mb-6 p-4 border-l-2 text-[0.9rem] leading-relaxed" style="background: rgba(111, 90, 75, 0.06); border-color: var(--color-primary); color: var(--color-on-surface);">
          Sign-in link sent. Check your inbox at <strong>{sent}</strong>. The link expires in one hour.
        </div>
      )}

      {!sent && (
        <form method="post" action="/auth/signin" class="space-y-5">
          <div>
            <label for="email" class="label block mb-2">Email</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              autocomplete="email"
              autofocus
              placeholder="you@example.com"
              class="w-full px-4 py-3 bg-[var(--color-surface-container-lowest)] border border-[var(--color-outline-variant)] focus:border-[var(--color-primary)] focus:outline-none transition-colors font-[var(--font-body)] text-[1rem]"
            />
          </div>
          <button
            type="submit"
            class="w-full py-3.5 bg-[var(--color-on-surface)] text-[var(--color-surface)] font-[var(--font-label)] text-[0.72rem] uppercase tracking-[0.22em] hover:bg-[var(--color-primary)] transition-colors"
          >
            Send sign-in link
          </button>
        </form>
      )}

      <p class="text-center mt-8 text-[0.8rem] italic text-[var(--color-on-surface-variant)]">
        This is the private administration for amitabhparti.com. If you're here by accident, <a href="/" class="link-editorial">return to the site</a>.
      </p>
    </div>
  </section>
</AdminLayout>
