---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getRecentPosts, formatDate } from "../data/posts";
import { getSettings } from "../lib/settings";

const recent = await getRecentPosts(3);
const settings = await getSettings();
const { identity, home } = settings;

const { quote, highlight, attribution } = settings.hero;
const hIdx = highlight ? quote.indexOf(highlight) : -1;
const quoteBefore = hIdx >= 0 ? quote.slice(0, hIdx) : quote;
const quoteHighlight = hIdx >= 0 ? highlight : "";
const quoteAfter = hIdx >= 0 ? quote.slice(hIdx + highlight.length) : "";

const tagClass = (c: string | null) =>
  c === "Awareness" ? "tag tag--awareness"
  : c === "Reflection" ? "tag tag--reflection"
  : "tag";
---

<BaseLayout pageKey="home">

  <!-- HERO -->
  <section class="hero" aria-label="Introduction">
    <div class="hero__bg-line"></div>
    <div class="container hero__inner">

      <div class="hero__text">
        <p class="hero__eyebrow">
          <span class="hero__eyebrow-rule"></span>
          Senior Director &amp; Unit Head
        </p>
        <h1 class="hero__name">
          {identity.short_name || identity.name.split(' ')[1]
            ? <>Dr. {identity.name.replace('Dr. ', '').split(' ')[0]}<br /><em>{identity.name.replace('Dr. ', '').split(' ').slice(1).join(' ')}</em></>
            : identity.name
          }
        </h1>
        <p class="hero__subtitle">Internal Medicine · {identity.institution_short || identity.institution}, Gurgaon</p>

        <blockquote class="hero__quote">
          &ldquo;{quoteBefore}{quoteHighlight && <strong>{quoteHighlight}</strong>}{quoteAfter}&rdquo;
        </blockquote>

        <div class="hero__actions">
          <a href="/writing" class="btn btn--primary">Read the Essays</a>
          <a href="/about" class="btn btn--ghost">About Dr. Parti</a>
        </div>
      </div>

      {identity.portrait_url && (
        <div class="hero__card-wrap">
          <div class="place-card" role="img" aria-label="Dr. Amitabh Parti portrait card">
            <div class="place-card__img-wrap">
              <img
                src={identity.portrait_url}
                alt={identity.portrait_alt}
                class="place-card__img"
                width="620"
                height="520"
                loading="eager"
              />
              <div class="place-card__badges-left">
                <span class="pc-badge">Internal Medicine</span>
                <span class="pc-badge">{identity.institution_short || 'Fortis Memorial'}</span>
              </div>
              <div class="place-card__dots" aria-hidden="true">
                <span class="pc-dot pc-dot--active"></span>
                <span class="pc-dot"></span>
                <span class="pc-dot"></span>
              </div>
            </div>
            <div class="place-card__body">
              <div class="place-card__top-row">
                <h3 class="place-card__title">{identity.name}</h3>
              </div>
              <p class="place-card__meta">{identity.experience_years} yrs experience &bull; Gurgaon</p>
              <p class="place-card__desc">MBBS Gold Medallist · MD Internal Medicine · Senior Director &amp; Unit Head, {identity.institution_short || identity.institution}.</p>
              <div class="place-card__footer">
                <p class="place-card__price">
                  {identity.institution_short || 'Fortis Memorial'}<br />
                  <span class="place-card__price-sub">Sector 44, Gurugram</span>
                </p>
                <a href="/contact" class="pc-btn">
                  Contact
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CREDENTIALS STRIP -->
  <section class="strip" aria-label="Key credentials">
    <div class="container strip__inner">
      <div class="strip__item reveal">
        <p class="strip__label">Experience</p>
        <p class="strip__value">{identity.experience_years} <span>Years in Practice</span></p>
      </div>
      <div class="strip__divider" aria-hidden="true"></div>
      <div class="strip__item reveal">
        <p class="strip__label">Qualification</p>
        <p class="strip__value">MBBS <span>Gold Medallist, {identity.mbbs_year}</span></p>
      </div>
      <div class="strip__divider" aria-hidden="true"></div>
      <div class="strip__item reveal">
        <p class="strip__label">Specialisation</p>
        <p class="strip__value">MD <span>Internal Medicine, {identity.md_year}</span></p>
      </div>
      <div class="strip__divider" aria-hidden="true"></div>
      <div class="strip__item reveal">
        <p class="strip__label">Appointment</p>
        <p class="strip__value">Senior Director <span>{identity.institution_short || 'Fortis Memorial'}</span></p>
      </div>
    </div>
  </section>

  <!-- ABOUT INTRO -->
  <section class="about-intro" aria-labelledby="about-intro-heading">
    <div class="container about-intro__inner">
      <div class="about-intro__left reveal">
        <span class="section-label" id="about-intro-heading">About</span>
        <h2 class="about-intro__heading">
          A physician who believes<br />
          <em>precision is an act of respect.</em>
        </h2>
        <p class="about-intro__body" set:html={home.intro_paragraph_html} />
        <a href="/about" class="link-arrow">Read the full biography</a>
      </div>
      {identity.portrait_url && (
        <div class="about-intro__right reveal">
          <figure class="about-intro__portrait-frame">
            <img
              src={identity.portrait_url}
              alt={identity.portrait_alt}
              class="about-intro__portrait"
              width="480"
              height="600"
              loading="lazy"
            />
            <figcaption class="about-intro__caption">
              {identity.institution_short || identity.institution}<br />
              Sector 44, Gurugram
            </figcaption>
          </figure>
        </div>
      )}
    </div>
  </section>

  <!-- CLINICAL INTERESTS -->
  <section class="expertise" aria-labelledby="expertise-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label" id="expertise-heading">Areas of Clinical Expertise</span>
        <p class="section-header__meta">{identity.experience_years} years in practice</p>
      </div>
      <div class="expertise__grid">
        {settings.clinical_interests.map((t, i) => (
          <article class="expertise__card reveal">
            <span class="expertise__num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="expertise__title">{t.title}</h3>
            <p class="expertise__note">{t.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- WRITING PREVIEW -->
  <section class="writing-preview" aria-labelledby="writing-preview-heading">
    <div class="container">
      <div class="section-header section-header--light">
        <span class="section-label" id="writing-preview-heading">Recent Writing</span>
        <a href="/writing" class="link-arrow link-arrow--light">All essays</a>
      </div>

      <ul class="writing-list">
        {recent.map((p) => (
          <li class="writing-item reveal">
            <a href={`/writing/${p.slug}`} class="writing-item__link">
              <div class="writing-item__meta">
                <span class={tagClass(p.category)}>{p.category}</span>
                <span class="writing-item__time">{p.readingTime}</span>
              </div>
              <h3 class="writing-item__title">{p.title}</h3>
              <p class="writing-item__excerpt">{p.excerpt}</p>
              <span class="writing-item__arrow">Read →</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- PULL QUOTE -->
  <section class="pull-section" aria-label="Featured quote">
    <div class="container pull-section__inner">
      <svg class="pull-section__mark" width="48" height="36" viewBox="0 0 48 36" fill="none" aria-hidden="true">
        <path d="M0 36V22.5C0 10.08 8.16 2.94 24.48 0L26.4 3.78C18.96 5.76 15.24 9.78 14.88 15.84H21.6V36H0ZM26.4 36V22.5C26.4 10.08 34.56 2.94 50.88 0L52.8 3.78C45.36 5.76 41.64 9.78 41.28 15.84H48V36H26.4Z" fill="currentColor"/>
      </svg>
      {home.closing_quote ? (
        <blockquote class="pull-section__quote" set:html={home.closing_quote} />
      ) : (
        <blockquote class="pull-section__quote">
          Medicine is not the application of science to biology. It is the
          <em>translation of evidence into empathy,</em> within the constraints
          of a human life.
        </blockquote>
      )}
      <p class="pull-section__attr">{home.closing_quote_meta || 'From the writing · 2026'}</p>
    </div>
  </section>

  <!-- EMPANELMENTS -->
  <section class="empanelments" aria-labelledby="empanelments-heading">
    <div class="container">
      <div class="section-header">
        <span class="section-label" id="empanelments-heading">Empanelled Visiting Physician</span>
        <p class="section-header__meta">Corporate Health Partners</p>
      </div>
      <ul class="empanelments__grid">
        {settings.empanelments.map((e, i) => (
          <li class="empanelments__item reveal">
            <span class="empanelments__num">{String(i + 1).padStart(2, '0')}</span>
            {e}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CONTACT CTA -->
  <section class="contact-cta" aria-labelledby="contact-cta-heading">
    <div class="container contact-cta__inner">
      <div class="contact-cta__text reveal">
        <span class="section-label" id="contact-cta-heading">Professional Correspondence</span>
        <h2 class="contact-cta__heading">
          For media, teaching,<br />
          <em>or professional enquiry.</em>
        </h2>
        <p class="contact-cta__body">
          This site is not a channel for clinical consultation. For patient care,
          please contact {identity.institution_short || identity.institution} through
          their official systems. For media, fellowship, speaking, or editorial
          correspondence, please write directly.
        </p>
      </div>
      <div class="contact-cta__details reveal">
        <div>
          <p class="contact-cta__row-label">By Letter</p>
          <a href={`mailto:${settings.contact.email}`} class="contact-cta__email">
            {settings.contact.email}
          </a>
        </div>
        <div>
          <p class="contact-cta__row-label">In Clinic</p>
          <address class="contact-cta__address">
            {settings.address.hospital}<br />
            {settings.address.line2}
          </address>
          <a href="/contact" class="link-arrow" style="margin-top:0.75rem;display:inline-flex;">See the map</a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
