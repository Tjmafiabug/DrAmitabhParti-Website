---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BackToTop from '../../components/BackToTop.astro';
import { getAllPosts, getPost, formatDate } from '../../data/posts';
import { getSettings } from '../../lib/settings';

const settings = await getSettings();

const { slug } = Astro.params;
const post = await getPost(slug!);
if (!post) return new Response(null, { status: 404 });

const chipClass = (c: string | null) =>
  c === 'Awareness'  ? 'chip-category chip-awareness'
: c === 'Reflection' ? 'chip-category chip-reflection'
:                      'chip-category chip-essay';

const allPosts = await getAllPosts();
const related = allPosts.filter((p) => p.slug !== post.slug).slice(0, 2);

const base = settings.identity.site_url.replace(/\/$/, '');
const coverAbs = post.coverImageUrl
  ? (post.coverImageUrl.startsWith('http') ? post.coverImageUrl : `${base}${post.coverImageUrl}`)
  : undefined;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.excerpt ?? undefined,
  image: coverAbs ? [coverAbs] : undefined,
  datePublished: post.publishedAt || undefined,
  dateModified:  post.publishedAt || undefined,
  mainEntityOfPage: `${base}/writing/${post.slug}`,
  author:    { '@type': 'Person', name: settings.identity.name, url: base },
  publisher: { '@type': 'Person', name: settings.identity.name, url: base },
  articleSection: post.category ?? undefined,
};
---

<BaseLayout title={post.title} description={post.excerpt ?? undefined} ogImage={post.coverImageUrl ?? undefined} ogType="article">
  <script
    slot="head"
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify(articleJsonLd)}
  />

  <BackToTop />

  {/* ARTICLE HERO — dark band with metadata + title */}
  <section class="section-dark-hero">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-20">
      <div class="container-reading mx-auto">
        <div class="flex items-center gap-4 mb-6">
          <span class={chipClass(post.category)}>{post.category}</span>
          <span class="meta" style="color: var(--color-gold-soft); opacity: 0.8;">{formatDate(post.publishedAt)}</span>
          <span class="meta" style="color: var(--color-gold-soft); opacity: 0.6;">·</span>
          <span class="meta" style="color: var(--color-gold-soft); opacity: 0.8;">{post.readingTime}</span>
        </div>
        <h1 class="text-balance mb-6" style="color: #f4efdf; font-size: clamp(2rem, 4vw + 1rem, 3.5rem); line-height: 1.08;">
          {post.title}
        </h1>
        <p class="text-[1.15rem] md:text-[1.25rem] italic font-light text-pretty max-w-[36rem]" style="color: var(--color-gold-soft);">
          {post.excerpt}
        </p>
      </div>
    </div>
  </section>

  {/* COVER IMAGE — only when the admin uploaded one */}
  {post.coverImageUrl && (
    <section class="bg-[var(--color-surface)]">
      <div class="container-wide mx-auto px-5 md:px-6 pt-10 md:pt-16">
        <figure class="container-reading mx-auto">
          <img
            src={post.coverImageUrl}
            alt={post.excerpt ?? post.title}
            class="w-full h-auto block"
            style="aspect-ratio: 16/9; object-fit: cover;"
            loading="eager"
            width="1600"
            height="900"
          />
        </figure>
      </div>
    </section>
  )}

  {/* ARTICLE BODY */}
  <section class="bg-[var(--color-surface)]">
    <div class={`container-wide mx-auto px-5 md:px-6 ${post.coverImageUrl ? 'pt-10 md:pt-14' : 'pt-14 md:pt-24'} pb-14 md:pb-24`}>
      <article class="container-reading mx-auto">
        <div class="prose-article drop-cap" set:html={post.body} />

        <div class="mt-16 pt-8" style="border-top: 1px solid var(--color-outline-variant);">
          <p class="text-[0.88rem] italic leading-loose" style="color: var(--color-secondary);">
            This article is general educational content by Dr. Amitabh Parti.
            It is not a substitute for individual medical advice. Please consult a
            qualified physician for guidance specific to your condition.
          </p>
        </div>

        <!-- Respond to this essay — private mailto, in lieu of public comments -->
        <div class="mt-10 pt-6">
          <p class="label label-primary mb-3">Respond to this essay</p>
          <p class="text-[0.95rem] leading-relaxed text-[var(--color-on-surface-variant)] max-w-xl">
            Thoughts, questions, or a letter of your own? Dr. Parti reads correspondence at
            <a href={`mailto:${settings.contact.email}?subject=${encodeURIComponent(`Re: ${post.title}`)}`} class="link-editorial">{settings.contact.email}</a>.
            <span class="italic">Please do not send clinical questions or personal medical details — this is not a consultation channel.</span>
          </p>
        </div>

        <div class="mt-10 flex items-center justify-between text-[0.95rem]">
          <a href="/writing" class="link-editorial font-[var(--font-label)] text-[0.72rem] uppercase tracking-[0.2em]">← All writing</a>
          <a href="/" class="link-editorial font-[var(--font-label)] text-[0.72rem] uppercase tracking-[0.2em]">Home →</a>
        </div>
      </article>
    </div>
  </section>

  {/* CONTINUE READING — tonal shift, still light */}
  {related.length > 0 && (
    <section class="bg-[var(--color-surface-container-low)]">
      <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-16">
        <div class="container-page mx-auto">
          <div class="flex items-baseline gap-4 mb-10">
            <span class="rule-accent"></span>
            <h2 class="label label-strong">Continue Reading</h2>
          </div>
          <div class="grid gap-8 md:gap-12 md:grid-cols-2">
            {related.map((p) => (
              <a href={`/writing/${p.slug}`} class="group">
                <div class="flex items-center gap-3 mb-3">
                  <span class={chipClass(p.category)}>{p.category}</span>
                  <span class="meta">{formatDate(p.publishedAt)}</span>
                </div>
                <h3 class="font-[var(--font-headline)] text-2xl md:text-[1.6rem] leading-tight mb-3 group-hover:text-[var(--color-primary)] transition-colors">
                  {p.title}
                </h3>
                <p class="leading-relaxed text-[var(--color-on-surface-variant)] max-w-xl">{p.excerpt}</p>
                <span class="mt-4 inline-block meta opacity-0 group-hover:opacity-100 transition-opacity text-[var(--color-primary)]">Read →</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
