---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getAllPosts, formatDate } from '../../data/posts';

const all = await getAllPosts();

const chipClass = (c: string | null) =>
  c === 'Awareness'  ? 'chip-category chip-awareness'
: c === 'Reflection' ? 'chip-category chip-reflection'
:                      'chip-category chip-essay';
---

<BaseLayout title="Writing" description="Essays, notes, and educational articles on internal medicine and public health by Dr. Amitabh Parti.">
  <PageHero
    eyebrow="Writing"
    title="Essays, notes,"
    titleItalic="and educational articles."
    kicker="General writing on internal medicine, public health, and the quiet things that happen in consulting rooms. Educational only — please see the standing disclaimer at the foot of each article."
  />

  {/* ARTICLE LIST — light band */}
  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-20">
      <div class="flex justify-between items-end mb-10 md:mb-12">
        <h2 class="label label-strong">All Writing</h2>
        <span class="meta">{all.length} {all.length === 1 ? 'essay' : 'essays'}</span>
      </div>

      <ul class="divide-y divide-[var(--color-outline-variant)]/30">
        {all.map((p, i) => (
          <li>
            <a href={`/writing/${p.slug}`} class="group grid grid-cols-1 md:grid-cols-[1fr_auto] gap-4 md:gap-10 py-8 md:py-10 items-start -mx-2 px-2 transition-colors hover:bg-[var(--color-surface-container-low)]/50">
              <div>
                <div class="flex items-center gap-3 mb-3">
                  <span class={chipClass(p.category)}>{p.category}</span>
                  <span class="meta">{p.readingTime}</span>
                </div>
                <h3 class={`font-[var(--font-headline)] mb-3 leading-[1.1] text-balance group-hover:text-[var(--color-primary)] transition-colors ${i === 0 ? 'text-3xl md:text-4xl' : 'text-2xl md:text-[1.65rem]'}`}>
                  {p.title}
                </h3>
                <p class="text-[var(--color-on-surface-variant)] leading-relaxed max-w-2xl">
                  {p.excerpt}
                </p>
              </div>
              <div class="flex md:flex-col md:items-end gap-2 shrink-0 md:pt-1">
                <span class="meta">{formatDate(p.publishedAt)}</span>
                <span class="meta text-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity">Read →</span>
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>
</BaseLayout>
