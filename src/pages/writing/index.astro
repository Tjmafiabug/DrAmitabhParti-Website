---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getAllPosts, formatDate } from '../../data/posts';
import { getSettings } from '../../lib/settings';

const settings = await getSettings();
const hero = settings.heroes.writing;
const all = await getAllPosts();

const tagClass = (c: string | null) =>
  c === 'Awareness'  ? 'tag tag--awareness'
: c === 'Reflection' ? 'tag tag--reflection'
:                      'tag';
---

<BaseLayout pageKey="writing">

  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    titleItalic={hero.title_italic}
    kicker={hero.kicker || undefined}
  />

  <section class="writing-body">
    <div class="container">
      <div class="filter-bar" id="filter-bar">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="Essay">Essay</button>
        <button class="filter-btn" data-filter="Awareness">Awareness</button>
        <button class="filter-btn" data-filter="Reflection">Reflection</button>
      </div>

      <div class="writing-grid" id="writing-grid">
        {all.map((p) => (
          <a
            href={`/writing/${p.slug}`}
            class="article-card"
            data-category={p.category || 'Essay'}
          >
            <div class="article-card__meta">
              <span class={tagClass(p.category)}>{p.category || 'Essay'}</span>
              <span class="article-card__date">{formatDate(p.publishedAt)}</span>
            </div>
            <h2 class="article-card__title">{p.title}</h2>
            <p class="article-card__excerpt">{p.excerpt}</p>
            <div class="article-card__footer">
              <span class="article-card__time">{p.readingTime}</span>
              <span class="article-card__read">Read →</span>
            </div>
          </a>
        ))}
      </div>

      <div class="writing-disclaimer">
        <p>
          All articles are published for general education and public awareness.
          Nothing here constitutes individual medical advice. If you are unwell,
          please consult a qualified physician in person.
          See the <a href="/disclaimer">full disclaimer</a>.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>

<script is:inline>
  (function () {
    const bar = document.getElementById('filter-bar');
    const grid = document.getElementById('writing-grid');
    if (!bar || !grid) return;

    bar.addEventListener('click', (e) => {
      const btn = e.target.closest('.filter-btn');
      if (!btn) return;
      bar.querySelectorAll('.filter-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      const filter = btn.dataset.filter;
      grid.querySelectorAll('.article-card').forEach((card) => {
        card.style.display = (filter === 'all' || card.dataset.category === filter) ? '' : 'none';
      });
    });
  })();
</script>
