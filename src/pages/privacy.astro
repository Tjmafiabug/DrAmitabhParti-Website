---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getSettings } from '../lib/settings';
import { getPageBody } from '../lib/pages';

const settings = await getSettings();
const hero = settings.heroes.privacy;
const html = await getPageBody('privacy');
---

<BaseLayout pageKey="privacy">
  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    titleItalic={hero.title_italic}
    kicker={hero.kicker || undefined}
  />

  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-20">
      <article class="container-reading mx-auto prose-article" set:html={html} />
    </div>
  </section>
</BaseLayout>
