---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getSettings } from '../lib/settings';
import { getPageBody } from '../lib/pages';

const settings = await getSettings();
const { identity, heroes } = settings;
const hero = heroes.credentials;
const credentialsHtml = await getPageBody('credentials');
---

<BaseLayout pageKey="credentials">

  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    titleItalic={hero.title_italic}
    kicker={hero.kicker || undefined}
  />

  <!-- EDUCATION -->
  <section class="cred-section">
    <div class="container">
      <div class="cred-section-header">
        <span class="section-label">Education</span>
      </div>
      <div class="cred-list">
        <div class="cred-item reveal">
          <div>
            <p class="cred-item__title">MD — Internal Medicine</p>
            <p class="cred-item__sub">{identity.university}</p>
          </div>
          <p class="cred-item__year">{identity.md_year}</p>
        </div>
        <div class="cred-item reveal">
          <div>
            <p class="cred-item__title">MBBS — <mark>Gold Medallist</mark></p>
            <p class="cred-item__sub">{identity.university}</p>
          </div>
          <p class="cred-item__year">{identity.mbbs_year}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- APPOINTMENT -->
  <section class="cred-section cred-section--alt">
    <div class="container">
      <div class="cred-section-header">
        <span class="section-label">Current Appointment</span>
      </div>
      <div class="cred-list">
        <div class="cred-item reveal">
          <div>
            <p class="cred-item__title">Senior Director &amp; Unit Head, Internal Medicine</p>
            <p class="cred-item__sub">{identity.institution}, Sector 44, Gurugram</p>
          </div>
          <p class="cred-item__year">Present</p>
        </div>
      </div>
      {credentialsHtml ? (
        <div class="prose-article" style="margin-top: var(--space-lg); max-width: 640px;" set:html={credentialsHtml} />
      ) : (
        <p style="margin-top:var(--space-lg);font-size:0.9rem;font-weight:300;line-height:1.8;color:var(--ink-muted);max-width:640px;">
          {identity.experience_years} years in clinical practice. {parseInt(identity.md_year) ? new Date().getFullYear() - parseInt(identity.md_year) : 32} years post-specialisation. A practice built on rigour, patience, and the conviction that listening is the primary diagnostic instrument.
        </p>
      )}
    </div>
  </section>

  <!-- CLINICAL INTERESTS -->
  <section class="cred-section">
    <div class="container">
      <div class="cred-section-header">
        <span class="section-label">Clinical Interests</span>
      </div>
      <div class="interests-tags">
        {settings.clinical_interests.map((t) => (
          <span class="interests-tag">{t.title}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- EMPANELMENTS -->
  <section class="cred-section cred-section--alt">
    <div class="container">
      <div class="cred-section-header">
        <span class="section-label">Empanelled Visiting Physician</span>
      </div>
      <p style="font-size:0.85rem;font-weight:300;color:var(--ink-muted);margin-bottom:var(--space-lg);max-width:44rem;">
        Officially approved as an external consultant to the following corporate health programmes:
      </p>
      <div class="empanelments__grid">
        {settings.empanelments.map((e, i) => (
          <div class="empanelments__item reveal">
            <span class="empanelments__num">{String(i + 1).padStart(2, '0')}</span>
            {e}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FOOTER NOTE -->
  <p class="footer-note container">
    A professionally maintained CV. For media or fellowship correspondence, please see the
    <a href="/contact">contact page</a>.
  </p>

</BaseLayout>
