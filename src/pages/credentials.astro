---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site';
import { getSettings } from '../lib/settings';
import { getPageBody } from '../lib/pages';

const settings = await getSettings();
const credentialsHtml = await getPageBody('credentials');
---

<BaseLayout title="Credentials" description="Education, qualifications, positions, and professional affiliations of Dr. Amitabh Parti.">

  <PageHero
    eyebrow="Curriculum Vitae"
    title="The record,"
    titleItalic="in brief."
  />

  {/* EDUCATION */}
  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-16">
      <div class="container-page mx-auto">
        <div class="flex items-baseline gap-4 mb-8">
          <span class="rule-accent"></span>
          <h2 class="label label-strong">Education</h2>
        </div>
        <ul class="space-y-0 divide-y divide-[var(--color-outline-variant)]/30">
          <li class="grid grid-cols-[1fr_auto] gap-8 items-baseline py-5">
            <div>
              <p class="font-[var(--font-headline)] text-[1.3rem] md:text-[1.5rem] italic">MD — Internal Medicine</p>
              <p class="text-[var(--color-on-surface-variant)] mt-1">{site.university}</p>
            </div>
            <p class="meta">{site.mdYear}</p>
          </li>
          <li class="grid grid-cols-[1fr_auto] gap-8 items-baseline py-5">
            <div>
              <p class="font-[var(--font-headline)] text-[1.3rem] md:text-[1.5rem] italic">
                MBBS — <span class="not-italic text-[var(--color-primary)]">Gold Medallist</span>
              </p>
              <p class="text-[var(--color-on-surface-variant)] mt-1">{site.university}</p>
            </div>
            <p class="meta">{site.mbbsYear}</p>
          </li>
        </ul>
      </div>
    </div>
  </section>

  {/* CURRENT APPOINTMENT + EXPERIENCE — rendered from admin-edited body_html */}
  <section class="bg-[var(--color-surface-container-low)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-16">
      <div class="container-page mx-auto">
        <div class="flex items-baseline gap-4 mb-6">
          <span class="rule-accent"></span>
          <h2 class="label label-strong">Appointment &amp; Experience</h2>
        </div>
        <div class="prose-article max-w-none" set:html={credentialsHtml} />
      </div>
    </div>
  </section>

  {/* CLINICAL INTERESTS — warm paper gradient for gentle variety */}
  <section class="bg-paper-warm">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-16">
      <div class="container-page mx-auto">
        <div class="flex items-baseline gap-4 mb-8">
          <span class="rule-accent"></span>
          <h2 class="label label-strong">Clinical Interests</h2>
        </div>
        <ul class="flex flex-wrap gap-2.5">
          {settings.clinical_interests.map((t) => (
            <li class="chip">{t.title}</li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  {/* EMPANELMENTS — back to surface */}
  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-16">
      <div class="container-page mx-auto">
        <div class="flex items-baseline gap-4 mb-3">
          <span class="rule-accent"></span>
          <h2 class="label label-strong">Empanelled Visiting Physician</h2>
        </div>
        <p class="mb-8 text-[var(--color-on-surface-variant)] text-[0.95rem] max-w-xl">
          Officially approved as an external consultant to the following corporate health programmes:
        </p>
        <ul class="grid grid-cols-1 md:grid-cols-5 gap-4 md:gap-5">
          {settings.empanelments.map((e, i) => {
            const tops = [
              'var(--color-primary)',
              'var(--color-tertiary)',
              'var(--color-gold)',
              'var(--color-accent)',
              'var(--color-primary-container)',
            ];
            return (
              <li class="bg-[var(--color-surface-container-low)] p-5 relative">
                <span class="absolute top-0 left-0 h-[3px] w-10" style={`background: ${tops[i]};`}></span>
                <p class="meta mt-2 mb-2">№ {String(i + 1).padStart(2, '0')}</p>
                <p class="font-[var(--font-headline)] text-[1rem] leading-tight">{e}</p>
              </li>
            );
          })}
        </ul>
      </div>
    </div>
  </section>

  {/* FOOTER NOTE */}
  <section class="bg-[var(--color-surface-container-low)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-10">
      <p class="container-prose mx-auto text-center italic text-[0.9rem]" style="color: var(--color-secondary);">
        A professionally maintained CV. For media or fellowship correspondence, please see the
        <a href="/contact" class="link-editorial">contact page</a>.
      </p>
    </div>
  </section>
</BaseLayout>
