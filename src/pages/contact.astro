---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getSettings } from '../lib/settings';

const settings = await getSettings();
const { heroes, contact_page } = settings;
const hero = heroes.contact;
---

<BaseLayout pageKey="contact">

  <PageHero
    eyebrow={hero.eyebrow}
    title={hero.title}
    titleItalic={hero.title_italic}
    kicker={hero.kicker || undefined}
  />

  <section class="contact-body">
    <div class="container contact-body__inner">
      <div class="reveal">
        <div class="contact-notice">
          <p>
            This site is not a channel for clinical consultation. For patient care,
            appointment requests, or medical records, please contact
            {settings.contact.fortis_profile
              ? <a href={settings.contact.fortis_profile} target="_blank" rel="noopener">{settings.identity.institution_short || settings.identity.institution} through their official systems</a>
              : <span>{settings.identity.institution_short || settings.identity.institution} through their official systems</span>
            }.
            For emergencies, call your nearest hospital immediately.
          </p>
        </div>

        <p class="contact-detail-label">By Letter</p>
        <a href={`mailto:${settings.contact.email}`} class="contact-email">
          {settings.contact.email}
        </a>

        <p class="contact-detail-label">In Clinic</p>
        <address class="contact-address">
          {settings.address.hospital}<br />
          {settings.address.line1}<br />
          {settings.address.line2}<br />
          {settings.address.country}
        </address>
      </div>

      {contact_page.map_embed_url && (
        <div class="contact-map reveal">
          <iframe
            src={contact_page.map_embed_url}
            title={contact_page.map_iframe_title}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
          ></iframe>
          <p class="contact-map__caption">{settings.address.hospital} · Sector 44, Gurugram</p>
        </div>
      )}
    </div>
  </section>

</BaseLayout>
