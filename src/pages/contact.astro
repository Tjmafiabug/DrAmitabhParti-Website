---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getSettings } from '../lib/settings';

const settings = await getSettings();
---

<BaseLayout title="Contact" description="Practice address and professional correspondence for Dr. Amitabh Parti.">

  <PageHero
    eyebrow="Contact"
    title="Where to find"
    titleItalic="Dr. Parti."
  />

  {/* CLINICAL PRACTICE + MAP */}
  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-20">
      <div class="container-page mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-10 md:gap-16 items-start">
          <div>
            <div class="flex items-baseline gap-4 mb-6">
              <span class="rule-accent"></span>
              <h2 class="label label-strong">Clinical Practice</h2>
            </div>
            <p class="font-[var(--font-headline)] text-2xl leading-tight mb-3">{settings.address.hospital}</p>
            <address class="not-italic leading-[1.8] text-[var(--color-on-surface-variant)] mb-6">
              {settings.address.line1}<br />
              {settings.address.line2}<br />
              {settings.address.country}
            </address>
            <p class="text-[0.95rem] text-[var(--color-on-surface-variant)] leading-relaxed max-w-md">
              For clinical consultations, please use
              <a href={settings.contact.fortis_profile} rel="noopener" class="link-editorial">Fortis Memorial's official appointment page</a>.
            </p>
          </div>

          <div class="aspect-[4/3] w-full overflow-hidden border border-[var(--color-outline-variant)]/40">
            <iframe
              title="Fortis Memorial Research Institute, Gurgaon — map"
              src="https://www.google.com/maps?q=Fortis+Memorial+Research+Institute+Gurgaon&output=embed"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="w-full h-full border-0"
            ></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* PROFESSIONAL CORRESPONDENCE — tonal shift, still light */}
  <section class="bg-[var(--color-surface-container-low)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-12 md:py-20">
      <div class="container-page mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-10 md:gap-16 items-center">
          <div>
            <div class="flex items-baseline gap-4 mb-6">
              <span class="rule-accent"></span>
              <h2 class="label label-strong">Professional Correspondence</h2>
            </div>
            <p class="font-[var(--font-headline)] text-2xl md:text-3xl leading-tight mb-5 text-balance">
              For media enquiries, teaching invitations,<br />
              <span class="italic text-[var(--color-primary)]">or fellowship correspondence.</span>
            </p>
            <p class="text-[var(--color-on-surface-variant)] leading-relaxed max-w-xl text-[1rem] text-pretty">
              This site is not a channel for clinical consultation. Please route
              patient enquiries through Fortis Memorial's official systems.
            </p>
          </div>
          <div>
            <p class="label mb-3">By Letter</p>
            <a href={`mailto:${settings.contact.email}`} class="font-[var(--font-headline)] italic text-[1.5rem] md:text-[1.75rem] text-[var(--color-primary)] link-editorial">
              {settings.contact.email}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* CLOSING NOTE */}
  <section class="bg-[var(--color-surface)]">
    <div class="container-wide mx-auto px-5 md:px-6 py-10">
      <p class="container-prose mx-auto text-center italic text-[0.9rem]" style="color: var(--color-secondary);">
        This site is not a channel for clinical consultation or medical advice.
        Please route all patient enquiries through Fortis Memorial's official systems.
      </p>
    </div>
  </section>
</BaseLayout>
