# Supabase — amitabhparti.com
# Copy this file to .env and fill in the values from Supabase Project Settings → API.

# Browser-safe (anon / public key). The PUBLIC_ prefix exposes it to client code.
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only (service_role key). NO PUBLIC_ prefix.
# This key bypasses Row Level Security. Never ship it to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# The single admin email allowed to sign in to /admin.
# Magic links for any other email are rejected by middleware.
ADMIN_EMAIL=you@example.com
